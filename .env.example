# Google OAuth Client ID (Web application type) — public-safe, not a secret.
# See README.md "One-time Google Cloud setup" for how to create this.
VITE_GOOGLE_CLIENT_ID=

# ---- Optional: cloud sync via Firebase Realtime Database ----
# Leave these blank to run local-only (IndexedDB). Fill them in to share
# data across devices. All values come from Firebase console → Project
# settings → Your apps → SDK setup and configuration, and are public-safe
# (security comes from Auth + database rules, see README → Cloud sync).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_DATABASE_URL=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_APP_ID=

# ---- Optional: multi-user admin access ----
# The one Google account (email) allowed to see the Admin panel and view
# other signed-in users' data read-only. Leave blank to disable the admin
# panel entirely. This is only a UI show/hide switch — the REAL security
# boundary is the Firebase rules, see README → "Admin access".
VITE_ADMIN_EMAIL=
